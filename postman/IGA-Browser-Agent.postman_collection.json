		{
			"name": "Access Review",
			"item": [
				{
					"name": "Access Review (Single User)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 202) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('task_id', jsonData.task_id);",
									"    console.log('Task started: ' + jsonData.task_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"agent\": \"greenfield-access-review\",\n    \"inputs\": {\n        \"user_email\": \"jsmith@meritage.com\"\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/tasks",
							"host": ["{{base_url}}"],
							"path": ["api", "tasks"]
						},
						"description": "Read-only access review for a specific user. Extracts all roles, permissions, and group memberships.\n\n**Optional inputs:**\n- `user_email` — If provided, reviews a single user. If omitted, reviews all users."
					}
				},
