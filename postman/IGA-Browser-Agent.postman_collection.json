							"raw": "{{base_url}}/api/tasks",
							"host": ["{{base_url}}"],
							"path": ["api", "tasks"]
						},
						"description": "Read-only access review for ALL users. Iterates through the user list and extracts entitlements for each.\n\nNo approval required — this is a read-only operation."
					}
				}
			]
		},
		{
			"name": "Approval Callbacks",
			"item": [
				{
					"name": "Approve Task",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/approve/{{task_id}}",
							"host": ["{{base_url}}"],
							"path": ["approve", "{{task_id}}"]
						},
						"description": "Manually approve a task that is waiting for confirmation.\n\nThis is normally called by Teams adaptive card buttons, but can be triggered manually for testing."
					}
				},
				{
					"name": "Deny Task",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/deny/{{task_id}}",
							"host": ["{{base_url}}"],
							"path": ["deny", "{{task_id}}"]
						},
						"description": "Manually deny a task that is waiting for confirmation. The task will be marked as failed."
					}
				}
			]
