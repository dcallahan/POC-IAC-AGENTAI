{
	"info": {
		"name": "IGA Browser Agent",
		"description": "API collection for the IGA Browser Agent — triggers autonomous browser automation tasks for Identity Governance operations against Greenfield.AI.\n\n## Setup\n1. Set the `base_url` variable to your Container App URL or `http://localhost:8000` for local dev\n2. Run a task via any of the \"Start Task\" requests\n3. Copy the returned `task_id` into the `task_id` variable\n4. Poll status with \"Get Task Status\"\n\n## Autonomous Mode\nWhen `TEAMS_WEBHOOK_URL` is not set, all agents run fully autonomously with no approval required.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "task_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "System",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						},
						"description": "Verify the API is running and healthy."
					}
				},
				{
					"name": "List Available Agents",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/agents",
							"host": ["{{base_url}}"],
							"path": ["api", "agents"]
						},
						"description": "Returns all available YAML agent templates with their required inputs, types, and defaults."
					}
				},
				{
					"name": "Get Task Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/tasks/{{task_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "tasks", "{{task_id}}"]
						},
						"description": "Poll the status of a running task. Status values: running, completed, failed.\n\nSet the `task_id` collection variable after starting a task."
					}
				}
			]
		},
		{
			"name": "User Management",
			"item": [
				{
					"name": "Provision User (Add User)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 202) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('task_id', jsonData.task_id);",
									"    console.log('Task started: ' + jsonData.task_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"agent\": \"greenfield-provision\",\n    \"inputs\": {\n        \"full_name\": \"John Smith\",\n        \"email\": \"jsmith@meritage.com\",\n        \"department\": \"Engineering\",\n        \"title\": \"Software Developer\",\n        \"role\": \"user\"\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/tasks",
							"host": ["{{base_url}}"],
							"path": ["api", "tasks"]
						},
						"description": "Create a new user in Greenfield.AI.\n\n**Required inputs:**\n- `full_name` — User's full name\n- `email` — User's email address\n- `department` — Department name\n- `title` — Job title\n- `role` — Role to assign (e.g. user, admin)"
					}
				},
				{
					"name": "Deprovision User (Disable)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 202) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('task_id', jsonData.task_id);",
									"    console.log('Task started: ' + jsonData.task_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"agent\": \"greenfield-deprovision\",\n    \"inputs\": {\n        \"user_email\": \"jsmith@meritage.com\",\n        \"action\": \"disable\"\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/tasks",
							"host": ["{{base_url}}"],
							"path": ["api", "tasks"]
						},
						"description": "Disable or delete a user in Greenfield.AI.\n\n**Required inputs:**\n- `user_email` — Email of the user to deprovision\n\n**Optional inputs:**\n- `action` — `disable` (default) or `delete`"
					}
				},
				{
					"name": "Deprovision User (Delete)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 202) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('task_id', jsonData.task_id);",
									"    console.log('Task started: ' + jsonData.task_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"agent\": \"greenfield-deprovision\",\n    \"inputs\": {\n        \"user_email\": \"jsmith@meritage.com\",\n        \"action\": \"delete\"\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/tasks",
							"host": ["{{base_url}}"],
							"path": ["api", "tasks"]
						},
						"description": "Permanently delete a user from Greenfield.AI.\n\n**Required inputs:**\n- `user_email` — Email of the user to delete\n- `action` — Set to `delete`"
					}
				},
				{
					"name": "Enable Account",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 202) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('task_id', jsonData.task_id);",
									"    console.log('Task started: ' + jsonData.task_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"agent\": \"greenfield-enable-account\",\n    \"inputs\": {\n        \"user_email\": \"jsmith@meritage.com\"\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/tasks",
							"host": ["{{base_url}}"],
							"path": ["api", "tasks"]
						},
						"description": "Re-enable a previously disabled user account in Greenfield.AI.\n\n**Required inputs:**\n- `user_email` — Email of the disabled user to re-enable"
					}
				}
			]
		},
