flowchart TB
    CLI["🧑‍💻 <b>IGA Operator</b><br/>python -m orchestrator.main<br/>--agent template --input k=v"]

    CLI -->|"1. Select YAML template"| TEMPLATES

    subgraph TEMPLATES["📋 YAML Agent Factory — 6 IGA Workflows"]
        direction LR
        T1["Add User"]
        T2["Remove User"]
        T3["Add Entitlement"]
        T4["Remove Entitlement"]
        T5["Enable Account"]
        T6["Access Review"]
    end

    TEMPLATES -->|"2. Rendered instructions + inputs"| LOOP

    subgraph CORE["⚙️ Python Orchestrator"]
        direction LR
        LOOP["<b>Agentic Loop</b><br/><i>agent_loop.py</i><br/>While not complete:<br/>  screenshot → Claude → tool calls → execute"]
        TOOLS["<b>9 Browser Tools</b><br/><i>navigate, click, type_text</i><br/><i>screenshot, read_page, scroll</i><br/><i>select_option, task_complete</i><br/><i>request_confirmation</i>"]
    end

    LOOP <-->|"3. Screenshot + context ⬆️<br/>Tool calls ⬇️"| CLAUDE

    CLAUDE["🤖 <b>Claude Sonnet 4.6</b><br/><i>Azure AI Foundry — East US2</i><br/>Vision + Tool Use<br/>200K context window"]

    LOOP -->|"4. Execute tool calls"| BROWSER

    subgraph BROWSER["🌐 Browser Execution — Playwright + Headless Chrome"]
        direction LR
        CTRL["<b>Browser Controller</b><br/><i>NL descriptions →</i><br/><i>get_by_role / get_by_text</i><br/><i>get_by_label / get_by_placeholder</i>"]
        CTRL --> GF["🏠 <b>Greenfield.AI</b><br/><i>Next.js + Supabase</i>"]
        CTRL --> FUTURE["🔌 <b>Future Apps</b><br/><i>KnowBe4, Saviynt</i><br/><i>ServiceNow, etc.</i>"]
    end

    LOOP -->|"5. Confirmation gate?"| TEAMS
    TEAMS["💬 <b>Microsoft Teams</b><br/><i>Incoming Webhook → Adaptive Card</i><br/>Approve ✅ / Deny ❌<br/><i>Callback → resume or abort</i>"]
    TEAMS -->|"Approved / Denied"| LOOP

    LOOP -->|"6. Every step"| EVIDENCE

    subgraph EVIDENCE["📸 Evidence Pipeline"]
        direction LR
        CAPTURE["Screenshot capture<br/>SHA-256 hash"]
        CAPTURE --> UPLOAD["Upload to Blob<br/>Log to audit JSON"]
    end

    EVIDENCE -->|"7. Upload"| BLOB

    subgraph INFRA["☁️ Azure Infrastructure — Bicep Deployed"]
        direction LR
        BLOB["📦 <b>Blob Storage</b><br/><i>stigaagentdev</i><br/>iga-evidence/<br/>  {task_id}/{step}.png<br/>  {task_id}/audit_log.json"]
        KV["🔑 <b>Key Vault</b><br/><i>kv-iga-agent-dev</i><br/>foundry-api-key<br/>teams-webhook-url"]
        ENTRA["🛡️ <b>Entra ID</b><br/>Service Principal<br/>Managed Identity<br/>SSO Sessions"]
    end

    KV -.->|"secrets at startup"| CORE
    ENTRA -.->|"auth"| CLAUDE
    ENTRA -.->|"SSO sessions"| BROWSER

